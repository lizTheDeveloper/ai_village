{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["@webgpu/types"],
    "paths": {
      "@multiverse-studios/folkfork-bridge": ["./src/typings/folkfork-bridge.d.ts"]
    }
  },
  "include": ["src/**/*", "src/**/*.json", "../../env.d.ts"],
  "exclude": [
    "src/**/__tests__/**/*",
    "src/**/*.test.ts",
    "src/**/__benchmarks__/**/*",
    "src/**/*.bench.ts"
  ],
  "references": [
    { "path": "../types" },
    { "path": "../building-designer" },
    { "path": "../hierarchy-simulator" }
  ]
}
