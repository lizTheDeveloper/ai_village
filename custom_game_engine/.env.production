# Production environment overrides (loaded by vite build --mode production)

# LLM proxy — same-origin production server handles LLM proxy + sprite stubs
# under the /mvee base path (Traefik routes play.multiversestudios.xyz/mvee/* here)
VITE_LLM_PROXY_URL=/mvee

# API base URL — production server serves game + API under /mvee
VITE_API_URL=/mvee

# Planet server — same production server (routes return 404, game falls back to local-only)
VITE_PLANET_SERVER_URL=/mvee

# GlitchTip / Sentry error tracking
VITE_SENTRY_DSN=https://2959baf6-b29b-4961-bdb0-c80b440d67aa@errors.multiversestudios.xyz/2
