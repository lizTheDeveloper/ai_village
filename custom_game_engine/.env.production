# Production environment overrides (loaded by vite build --mode production)

# LLM proxy — browser calls the token proxy directly for auth + metering
VITE_LLM_PROXY_URL=https://proxy.themultiverse.school

# API base URL — production server serves game + API under /mvee
VITE_API_URL=/mvee

# Planet server — same production server (routes return 404, game falls back to local-only)
VITE_PLANET_SERVER_URL=/mvee
