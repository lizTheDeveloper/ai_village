# Production environment overrides (loaded by vite build --mode production)

# LLM proxy — empty means use SameOriginChatProxy which calls /api/llm/chat
# on the same-origin production server (production.ts). ProxyLLMProvider is for
# the external llm-token-proxy at api.multiversestudios.xyz (not yet wired up).
VITE_LLM_PROXY_URL=

# API base URL — production server serves game + API under /mvee
VITE_API_URL=/mvee

# Planet server — same production server (routes return 404, game falls back to local-only)
VITE_PLANET_SERVER_URL=/mvee

# GlitchTip / Sentry error tracking
VITE_SENTRY_DSN=https://2959baf6b29b4961bdb0c80b440d67aa@errors.multiversestudios.xyz/2
