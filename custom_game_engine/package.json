{
  "name": "@ai-village/game-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build > /dev/null 2>&1 || tsc --build",
    "build:stable": "npx tsx scripts/create-stable-build.ts",
    "build:prod": "mkdir -p demo/public/assets/sprites && rm -rf demo/public/assets/sprites/pixellab && cp -r packages/renderer/assets/sprites/pixellab demo/public/assets/sprites/pixellab && cp packages/renderer/assets/sprites/sprite-manifest.json demo/public/assets/sprites/pixellab/sprite-manifest.json && cd demo && npx vite build --config vite.config.prod.ts",
    "dev": "tsc --build --watch",
    "test": "npm run validate-data && vitest run",
    "test:perf": "vitest run --config vitest.config.perf.ts",
    "test:watch": "vitest",
    "test:coverage": "npm run validate-data && vitest run --coverage",
    "test:all": "npm run test --workspaces",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:chunk-generation": "playwright test chunk-generation",
    "test:update-baseline": "bash scripts/ci-check-regression.sh --update-baseline",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench",
    "lint": "eslint .",
    "lint:errors": "eslint . --quiet",
    "clean": "rm -rf packages/*/dist",
    "audit:systems": "npx tsx packages/core/src/scripts/audit-system-interactions.ts",
    "check:circular": "npx tsx scripts/check-circular.ts",
    "check:interfaces": "npx tsx scripts/check-interface-duplication.ts",
    "detect-oscillation": "npx tsx scripts/detect-oscillation.ts",
    "metrics-server": "npx tsx --no-cache scripts/metrics-server.ts",
    "validate-data": "npx tsx scripts/validate-all-data.ts",
    "validate-plants": "npx tsx scripts/validate-plants.ts",
    "validate:blueprints": "npx tsx scripts/validate-blueprints.ts",
    "validate:runtime": "npx tsx scripts/validate-package-runtime.ts",
    "watch:validate": "npx tsx scripts/watch-validate.ts",
    "test:riddles": "npx tsx scripts/test-riddle-generation.ts",
    "generate-wiki": "npx tsx scripts/generate-wiki.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/chokidar": "1.7.5",
    "@types/node": "20.10.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "6.13.0",
    "@typescript-eslint/parser": "6.13.0",
    "@webgpu/types": "0.1.69",
    "canvas": "3.2.0",
    "chokidar": "5.0.0",
    "eslint": "8.54.0",
    "glob": "13.0.0",
    "husky": "9.1.7",
    "jsdom": "27.3.0",
    "madge": "8.0.0",
    "playwright": "1.57.0",
    "tsx": "4.21.0",
    "typescript": "5.3.3",
    "vitest": "4.0.16",
    "ws": "8.18.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.71.2",
    "@sentry/browser": "10.45.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "concurrently": "9.2.1",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "pg": "8.20.0",
    "sharp": "0.34.5"
  },
  "optionalDependencies": {
    "@mlc-ai/web-llm": "0.2.82",
    "@nicepkg/wllama": "npm:null@*"
  }
}
