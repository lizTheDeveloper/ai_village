# Whitelist approach — ignore everything, then allow only what the Dockerfile needs.
# This keeps the Docker build context from ballooning (5.4GB → ~200MB).

# Ignore everything first
*

# Allow package manifests (COPY package.json / package-lock.json)
!package.json
!package-lock.json
!tsconfig.json

# Allow source packages (COPY packages/)
!packages/
packages/*/dist/
packages/*/node_modules/
packages/*/__tests__/
packages/*/src/__tests__/
packages/*/src/systems/__tests__/

# Allow demo app (COPY demo/)
!demo/
demo/dist/
demo/node_modules/

# Allow .env files (Dockerfile copies .env* for VITE_ build-time vars)
# TODO: migrate to --build-arg for secrets — VITE_*_API_KEY vars get embedded
# in the client bundle. Production should use server-side proxy only.
!.env
!.env.*

# Never include logs
*.log
