#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

cd custom_game_engine

echo "🔍 Running data validators..."

# Install glob if not already installed (needed for validators)
if ! npm list glob > /dev/null 2>&1; then
  echo "📦 Installing glob dependency..."
  npm install --save-dev glob --silent
fi

# Run validators
npm run validate-data

# Check exit code
if [ $? -ne 0 ]; then
  echo "❌ Validation failed. Please fix errors before committing."
  exit 1
fi

echo "✅ Data validation passed!"

# --- MUL-4531: Mandatory build gate ---
echo "🔨 Running TypeScript build check..."
npm run build --silent 2>&1

if [ $? -ne 0 ]; then
  echo "❌ TypeScript build failed. Fix type errors before committing."
  exit 1
fi

echo "✅ Build check passed!"

# --- MUL-4531: Stale .js check ---
STALE_JS=$(find packages -path "*/src/*.js" -type f 2>/dev/null)
if [ -n "$STALE_JS" ]; then
  echo "❌ Stale .js files found in src/:"
  echo "$STALE_JS"
  echo "Run: find packages -path '*/src/*.js' -type f -delete"
  exit 1
fi

echo "✅ All pre-commit checks passed!"
